VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "FinancialStatements"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
'==============================================================================
'   Ќа–±Џ”•\
'==============================================================================
Option Explicit

'Ќа–±Џ”•\Ѓi‘ЭЋШ‘ОЏЖ•\ЃAђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘Ѓj‚МЌА•W
Private Const styFinancialStatements = 6 'Ќа–±Џ”•\‚МЉJЋn€К’u


'==============================================================================
'   ѓNѓ‰ѓX‚МЏ‰Љъ‰»
'==============================================================================
Private Sub Class_Initialize()
    Call SheetClear          '‘ЌЉЁ’иЊі’ ЃEЌЎЉъЋАђС‚МѓNѓЉѓA
End Sub

'==============================================================================
'   ѓNѓ‰ѓX‚М‰р•ъ
'==============================================================================
Private Sub Class_Terminate()

End Sub

'==============================================================================
'       Ќа–±Џ”•\‚М‚OЏ‰Љъ‰»
'==============================================================================
Sub SheetClear()

    '----------------------------------
    '   •Пђ”ђйЊѕ
    '----------------------------------
    Dim wsBS As Worksheet
    Dim wsPL As Worksheet
    
    '----------------------------------
    '   Џ‰Љъ‰»
    '----------------------------------
    Set wsBS = ThisWorkbook.Worksheets("‡C‘ЭЋШ‘ОЏЖ•\")
    Set wsPL = ThisWorkbook.Worksheets("‡Dђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘")
        
    Dim yOutBS As Long
    Dim yOutPL As Long

    '‘ЭЋШ‘ОЏЖ•\‚Ц
    yOutBS = styFinancialStatements
    Do
        If IsNull(wsBS.Cells(yOutBS, 1)) Or IsEmpty(wsBS.Cells(yOutBS, 1)) Then
        Else
            If wsBS.Cells(yOutBS, 1) = -1 Then
                Exit Do
            Else
                wsBS.Cells(yOutBS, 6) = 0
                wsBS.Cells(yOutBS, 7) = 0
            End If
        End If
        yOutBS = yOutBS + 1
    Loop
    
    'ђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘‚Ц
    yOutPL = styFinancialStatements
    Do
        If IsNull(wsPL.Cells(yOutPL, 1)) Or IsEmpty(wsPL.Cells(yOutPL, 1)) Then
        Else
            If wsPL.Cells(yOutPL, 1) = -1 Then
                Exit Do
            Else
                wsPL.Cells(yOutPL, 6) = 0
                wsPL.Cells(yOutPL, 7) = 0
            End If
        End If
        yOutPL = yOutPL + 1
    Loop

End Sub

'==============================================================================
'       Ќа–±Џ”•\‚ЦЏo—Н
'------------------------------------------------------------------------------
'   Contents:
'       ђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘ЃAЋб‚µ‚­‚Н‘ЭЋШ‘ОЏЖ•\‚М
'       Ћw’и‚МЉЁ’и‰И–ЪѓRЃ[ѓh‚М—“‚ЙЃA‹аЉz‚рЏo—Н‚µ‚Ь‚·ЃB
'
'   Input:
'       id      ЉЁ’и‰И–ЪѓRЃ[ѓh
'       x       Џo—Н‚wЌА•W
'       iMoney  ‹аЉz
'
'   Output:
'       Sheet "ђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘"
'       Sheet "‘ЭЋШ‘ОЏЖ•\"
'
'==============================================================================
Sub OutFinancialStatements(idAccount As Variant, iColumn As Variant, iMoney As Currency)

    '----------------------------------
    '   •Пђ”ђйЊѕ
    '----------------------------------
    Dim wsBS As Worksheet
    Dim wsPL As Worksheet
    
    Dim yOutBS As Long
    Dim yOutPL As Long
    Dim flagErr As Boolean

    '----------------------------------
    '   Џ‰Љъ‰»
    '----------------------------------
    Set wsBS = ThisWorkbook.Worksheets("‡C‘ЭЋШ‘ОЏЖ•\")
    Set wsPL = ThisWorkbook.Worksheets("‡Dђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘")
    
    'Ќа–±Џ”•\‚Ц‚МЏo—Н
    If (idAccount < 30000) Then
        '‘ЭЋШ‘ОЏЖ•\‚Ц
        yOutBS = 6
        flagErr = True
        Do
            If IsNull(wsBS.Cells(yOutBS, 1)) Or IsEmpty(wsBS.Cells(yOutBS, 1)) Then
            Else
                If wsBS.Cells(yOutBS, 1) = -1 Then
                    Exit Do
                ElseIf wsBS.Cells(yOutBS, 1) = idAccount Then
                    If idAccount >= 10000 And idAccount < 20000 Then
                        'ЋШ•ы
                        wsBS.Cells(yOutBS, iColumn) = iMoney
                    Else
                        '‘Э•ы
                        wsBS.Cells(yOutBS, iColumn) = -iMoney
                    End If
                    flagErr = False
                End If
            End If
            yOutBS = yOutBS + 1
        Loop
        If flagErr = True Then
            MsgBox "‘ЭЋШ‘ОЏЖ•\‚ЙЉЁ’и‰И–Ъ‚Є‚ ‚и‚Ь‚№‚сЃBЃFЉЁ’и‰И–ЪѓRЃ[ѓhЃЃ" & str(idAccount)
            End
        End If
        
    Else
        'ђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘‚Ц
        yOutPL = 6
        flagErr = True
        Do
            If IsNull(wsPL.Cells(yOutPL, 1)) Or IsEmpty(wsPL.Cells(yOutPL, 1)) Then
            Else
                If wsPL.Cells(yOutPL, 1) = -1 Then
                    Exit Do
                ElseIf wsPL.Cells(yOutPL, 1) = idAccount Then
                    If idAccount >= 30000 And idAccount < 40000 Then
                        'ЏWЊvЊ‹‰К
                        wsPL.Cells(yOutPL, iColumn) = iMoney
                    ElseIf idAccount >= 40000 And idAccount < 50000 Then
                        'ЊoЏнЋы‰v
                        wsPL.Cells(yOutPL, iColumn) = -iMoney
                    ElseIf idAccount >= 50000 And idAccount < 60000 Then
                        'ЊoЏн”п—p
                        wsPL.Cells(yOutPL, iColumn) = iMoney
                    ElseIf idAccount >= 60000 And idAccount < 70000 Then
                        'ЊoЏнЉOЋы‰v
                        wsPL.Cells(yOutPL, iColumn) = -iMoney
                    ElseIf idAccount >= 70000 And idAccount < 80000 Then
                        'ЊoЏнЉO”п—p
                        wsPL.Cells(yOutPL, iColumn) = iMoney
                    End If
                    flagErr = False
                End If
            End If
            yOutPL = yOutPL + 1
        Loop
        If flagErr = True Then
            MsgBox "ђі–ЎЌаЋY‘ќЊёЊvЋZЏ‘‚ЙЉЁ’и‰И–Ъ‚Є‚ ‚и‚Ь‚№‚сЃBЃFЉЁ’и‰И–ЪѓRЃ[ѓhЃЃ" & str(idAccount)
            End
        End If

    End If

End Sub

